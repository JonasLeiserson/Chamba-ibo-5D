---
import '../styles/global.css';
import CategoriaCard from '../componentes/CategoriaCard.astro';
import palabras from '../data/palabras.json';

const emojis = {
  animales: "🐾",
  comida: "🍕",
  paises: "🌎",
  tecnologia: "💻"
};

const categorias = Object.keys(palabras);
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Impostor Word Generator</title>
  </head>
  <body>
    
    <button id="theme-toggle" class="theme-btn neo-card rounded-2xl text-2xl active:scale-90 transition-transform">
      🌙
    </button>

    <header class="max-w-xl w-full text-center py-10">
      <h1 class="text-6xl font-black italic tracking-tighter uppercase mb-2" style="-webkit-text-stroke: 1.5px black;">
        Impostor <span class="text-blue-600">Word</span>
      </h1>
      <p class="font-bold underline decoration-blue-500 decoration-4 text-xl">chamba ibo</p>
    </header>

    <main class="max-w-xl w-full">
      
      <section id="setup-ui" class="neo-card p-8 animate-game">
        <h2 class="text-2xl font-black mb-8 uppercase italic border-b-4 border-black inline-block">1. Categoría</h2>
        
        <div class="grid grid-cols-2 gap-4 mb-12">
          {categorias.map((cat) => (
            <label class="cursor-pointer relative">
              <input type="radio" name="cat" value={cat} class="hidden cat-input" />
              <div class="cat-design neo-card p-6 text-center">
                <span class="text-4xl block mb-2">{emojis[cat]}</span>
                <span class="font-black uppercase text-xs tracking-widest">{cat}</span>
              </div>
            </label>
          ))}
        </div>

        <h2 class="text-2xl font-black mb-4 uppercase italic border-b-4 border-black inline-block">2. Jugadores</h2>
        <input type="number" id="input-jugadores" min="3" value="3" 
          class="w-full p-6 neo-card mb-12 text-5xl font-black text-center focus:outline-none bg-white text-black" />

        <button id="btn-iniciar" class="w-full p-6 neo-btn text-3xl italic">
       Iniciar 
        </button>
      </section>

      <section id="game-ui" class="hidden animate-game neo-card p-8 bg-zinc-900 text-white text-center">
        <div id="jugador-badge" class="inline-block bg-blue-500 text-white px-6 py-2 font-black uppercase mb-10 -rotate-1 border-2 border-white">
          Jugador 1
        </div>
        
        <div class="revelar-box bg-zinc-800 p-16 border-4 border-dashed border-zinc-600 mb-8 cursor-pointer active:border-blue-500 transition-all">
          <p class="text-xs font-bold mb-4 text-zinc-500 uppercase tracking-widest">Mantené para revelar</p>
          <span id="palabra-display" class="text-5xl font-black tracking-tighter block uppercase">---</span>
        </div>

        <div class="bg-zinc-800 p-4 border-2 border-zinc-700 mb-8 min-h-[60px] flex items-center justify-center">
            <p id="pista-api" class="text-blue-400 font-bold italic text-sm"></p>
        </div>

        <button id="btn-siguiente" class="w-full p-6 neo-btn bg-white text-black hover:bg-zinc-100">
          LISTO
        </button>
      </section>

      <section id="final-ui" class="hidden animate-game text-center">
        <div class="neo-card p-10 bg-blue-600 text-white inline-block mx-auto max-w-sm">
          <h2 class="text-5xl font-black mb-6 uppercase italic">¡LISTO!</h2>
          <p class="text-lg font-bold mb-10 leading-tight">Roles asignados. <br/> El impostor está entre ustedes.</p>
          <button onclick="location.reload()" class="w-full p-5 neo-btn bg-yellow-400 text-black text-xl">
            REINICIAR
          </button>
        </div>
      </section>

    </main>

    <script define:vars={{ palabras }}>
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      const setTheme = (isDark) => {
        html.classList.toggle('dark', isDark);
        toggle.textContent = isDark ? '☀️' : '🌙';
      };

      toggle.addEventListener('click', () => {
        const isDark = html.classList.toggle('dark');
        setTheme(isDark);
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      if (localStorage.getItem('theme') === 'dark') setTheme(true);

      const setup = document.getElementById('setup-ui');
      const game = document.getElementById('game-ui');
      const final = document.getElementById('final-ui');
      const btnIniciar = document.getElementById('btn-iniciar');
      const btnSiguiente = document.getElementById('btn-siguiente');
      const display = document.getElementById('palabra-display');
      const pistaTxt = document.getElementById('pista-api');
      const badge = document.getElementById('jugador-badge');

      let estado = { total: 0, actual: 1, imp: 0, palabra: "" };

      async function getPista(p) {
        pistaTxt.textContent = "Buscando pista...";
        try {
          const r = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${p}`);
          const d = await r.json();
          pistaTxt.textContent = d[0]?.meanings[0]?.definitions[0]?.definition || "Sin pista.";
        } catch { pistaTxt.textContent = ""; }
      }

      btnIniciar.addEventListener('click', () => {
        const cat = document.querySelector('input[name="cat"]:checked');
        if (!cat) return alert("¡CATEGORÍA!");
        estado.total = parseInt(document.getElementById('input-jugadores').value);
        estado.imp = Math.floor(Math.random() * estado.total) + 1;
        estado.palabra = palabras[cat.value][Math.floor(Math.random() * palabras[cat.value].length)];
        setup.classList.add('hidden');
        game.classList.remove('hidden');
        render();
      });

      function render() {
        badge.textContent = `Jugador ${estado.actual}`;
        pistaTxt.textContent = "";
        if (estado.actual === estado.imp) {
          display.textContent = "IMPOSTOR";
          pistaTxt.textContent = "¡Mentí!";
        } else {
          display.textContent = estado.palabra.toUpperCase();
          getPista(estado.palabra);
        }
      }

      btnSiguiente.addEventListener('click', () => {
        if (estado.actual < estado.total) {
          estado.actual++;
          render();
        } else {
          game.classList.add('hidden');
          final.classList.remove('hidden');
        }
      });
    </script>
  </body>
</html>