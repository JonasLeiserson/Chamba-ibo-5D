---
import '../styles/global.css';
import palabraslocales from '../data/palabras.json';

const emojis = {
  animales: "🐾",
  comida: "🍕",
  paises: "🌎",
  tecnologia: "💻",
  custom: "✨" // Emoji por defecto para las creadas por vos
};

const categoriasEstaticas = Object.keys(palabraslocales);
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Impostor Word</title>
  </head>
  <body class="transition-colors duration-300">
    
    <button id="theme-toggle" class="theme-btn neo-card rounded-2xl text-2xl bg-[var(--card)] text-[var(--text)]">
      🌙
    </button>

    <header class="max-w-xl w-full text-center py-10">
      <h1 class="text-6xl font-black italic tracking-tighter uppercase mb-2" style="-webkit-text-stroke: 1.5px var(--text);">
        Impostor <span class="text-blue-600">Word</span>
      </h1>
      <p class="font-bold underline decoration-blue-500 decoration-4 text-xl">chamba ibo</p>
    </header>

    <main class="max-w-xl w-full px-4">
      
      <!-- LOGIN -->
      <section id="login-ui" class="neo-card p-8 animate-game">
        <h2 class="text-3xl font-black mb-6 uppercase italic">Login</h2>
        <div class="space-y-4">
          <input type="text" id="login-user" placeholder="Usuario" class="w-full p-4 neo-card bg-white text-black focus:outline-none" />
          <input type="password" id="login-pass" placeholder="contraseña" class="w-full p-4 neo-card bg-white text-black focus:outline-none" />
          <button id="btn-entrar" class="w-full p-4 neo-btn bg-blue-600 text-white text-xl">ENTRAR</button>
          <p class="text-center font-bold mt-4 text-sm">
            ¿No tenés cuenta? <button id="go-register" class="text-blue-600 underline">Registrate</button>
          </p>
        </div>
      </section>

      <!-- REGISTRO -->
      <section id="register-ui" class="hidden neo-card p-8 animate-game">
        <h2 class="text-3xl font-black mb-6 uppercase italic">Registro</h2>
        <div class="space-y-4">
          <input type="text" id="reg-user" placeholder="Usuario" class="w-full p-4 neo-card bg-white text-black focus:outline-none" />
          <input type="password" id="reg-pass" placeholder="contraseña" class="w-full p-4 neo-card bg-white text-black focus:outline-none" />
          <button id="btn-crear-cuenta" class="w-full p-4 neo-btn bg-green-500 text-white text-xl">CREAR CUENTA</button>
          <button id="go-login" class="w-full p-2 font-bold text-xs uppercase opacity-50">Volver</button>
        </div>
      </section>

      <!-- SETUP (Categorías y Jugadores) -->
      <section id="setup-ui" class="hidden neo-card p-8 animate-game">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-2xl font-black uppercase italic border-b-4 border-blue-500 inline-block">1. Categoría</h2>
            <span id="user-display" class="text-xs font-black bg-zinc-200 px-2 py-1 neo-card text-black"></span>
        </div>
        
        <!-- Contenedor Grid para todas las categorías -->
        <div class="grid grid-cols-2 gap-4 mb-12" id="contenedor-categorias">
          {categoriasEstaticas.map((cat) => (
            <label class="cursor-pointer">
              <input type="radio" name="cat" value={cat} class="hidden cat-input" />
              <div class="cat-design neo-card p-6 text-center bg-[var(--card)]">
                <span class="text-4xl block mb-2">{emojis[cat]}</span>
                <span class="font-black uppercase text-xs tracking-widest">{cat}</span>
              </div>
            </label>
          ))}
          
          <!-- El botón de "Nueva" siempre al final -->
          <button id="btn-nueva-cat" class="neo-card p-6 flex flex-col items-center justify-center bg-white text-black border-dashed">
            <span class="text-5xl font-black">+</span>
            <span class="font-black uppercase text-[10px] mt-2">Nueva</span>
          </button>
        </div>

        <h2 class="text-2xl font-black mb-4 uppercase italic border-b-4 border-blue-500 inline-block">2. Jugadores</h2>
        <input type="number" id="input-jugadores" min="3" value="3" class="w-full p-6 neo-card mb-12 text-5xl font-black text-center bg-[var(--card)]" />
        <button id="btn-iniciar" class="w-full p-6 neo-btn text-3xl italic">Iniciar</button>
        <button id="btn-logout" class="w-full mt-4 text-xs font-bold uppercase opacity-50 underline">Cerrar Sesión</button>
      </section>

      <!-- JUEGO -->
      <section id="game-ui" class="hidden animate-game neo-card p-8 bg-zinc-900 text-white text-center">
        <div id="jugador-badge" class="inline-block bg-blue-500 text-white px-6 py-2 font-black uppercase mb-10 -rotate-1 border-2 border-white">Jugador 1</div>
        <div class="revelar-box bg-zinc-800 p-16 border-4 border-dashed border-zinc-600 mb-8 cursor-pointer group">
          <p class="text-xs font-bold mb-4 text-zinc-500 uppercase tracking-widest">Mantené para revelar</p>
          <span id="palabra-display" class="text-5xl font-black tracking-tighter block uppercase text-white blur-xl opacity-0 group-active:blur-none group-active:opacity-100 transition-all duration-200">---</span>
        </div>
        <div class="bg-zinc-800 p-4 border-2 border-zinc-700 mb-8 min-h-[60px] flex items-center justify-center">
            <p id="pista-api" class="text-blue-400 font-bold italic text-sm"></p>
        </div>
        <button id="btn-siguiente" class="w-full p-6 neo-btn bg-white text-black">LISTO</button>
      </section>

      <!-- FINAL -->
      <section id="final-ui" class="hidden animate-game text-center">
        <div class="neo-card p-10 bg-blue-600 inline-block mx-auto max-w-sm">
          <h2 class="text-5xl font-black mb-6 uppercase italic text-white tracking-tighter">¡LISTO!</h2>
          <button id="btn-reiniciar" class="w-full p-5 neo-btn bg-yellow-400 text-black text-xl">OTRA RONDA</button>
        </div>
      </section>
    </main>

    <!-- MODAL NUEVA CATEGORIA -->
    <div id="modal-cat" class="fixed inset-0 z-[100] flex items-center justify-center hidden p-4 bg-black/60 backdrop-blur-sm">
        <div class="neo-card bg-[var(--card)] text-[var(--text)] w-full max-w-md p-8 animate-game">
            <h3 class="text-3xl font-black uppercase italic mb-6">Nueva Categoría</h3>
            <input type="text" id="cat-name" placeholder="Nombre del pack" class="w-full p-4 neo-card bg-white text-black mb-4 focus:outline-none" />
            <textarea id="cat-words" placeholder="Palabra 1, Palabra 2, Palabra 3..." class="w-full p-4 neo-card bg-white text-black h-32 resize-none focus:outline-none"></textarea>
            <div class="grid grid-cols-2 gap-4 mt-8">
                <button id="btn-cancelar" class="p-4 neo-btn bg-zinc-200 text-black">Cerrar</button>
                <button id="btn-guardar" class="p-4 neo-btn bg-blue-600 text-white">Guardar</button>
            </div>
        </div>
    </div>

    <script define:vars={{ palabraslocales, emojis }}>
      // Unificamos todas las palabras en un solo objeto manejable
      let TODAS_LAS_PALABRAS = { ...palabraslocales };

      const views = {
        login: document.getElementById('login-ui'),
        register: document.getElementById('register-ui'),
        setup: document.getElementById('setup-ui'),
        game: document.getElementById('game-ui'),
        final: document.getElementById('final-ui')
      };

      const pistaTxt = document.getElementById('pista-api');
      let estado = { total: 0, actual: 1, imp: 0, palabra: "" };

      function showView(viewName) {
        Object.values(views).forEach(v => v.classList.add('hidden'));
        views[viewName].classList.remove('hidden');
      }

      function checkAuth() {
        const user = sessionStorage.getItem('user');
        if (user) {
          document.getElementById('user-display').textContent = `@${user}`;
          showView('setup');
          obtenerCategorias(); 
        } else { 
          showView('login'); 
        }
      }

      // --- LOGICA DE LOGIN/REGISTRO ---
      document.getElementById('btn-entrar').onclick = async () => {
        const u = document.getElementById('login-user').value.trim();
        const p = document.getElementById('login-pass').value;
        if (!u || !p) return alert("Ingresá datos");

        const res = await fetch('/Endpoints/login', {
          method: 'POST',
          body: JSON.stringify({ usuario: u, contraseña: p })
        });
        const data = await res.json();
        if (res.ok) {
          sessionStorage.setItem('user', data.username);
          checkAuth();
        } else { alert(data.error); }
      };

      document.getElementById('btn-crear-cuenta').onclick = async () => {
        const u = document.getElementById('reg-user').value.trim();
        const p = document.getElementById('reg-pass').value;
        if (!u || !p) return alert("Completá campos");

        const res = await fetch('/Endpoints/registro', {
          method: 'POST',
          body: JSON.stringify({ usuario: u, contraseña: p })
        });
        if (res.ok) {
          alert("Cuenta creada");
          showView('login');
        } else {
          const data = await res.json();
          alert(data.error);
        }
      };

      // --- LOGICA DEL JUEGO ---
      document.getElementById('btn-iniciar').onclick = () => {
        const catInput = document.querySelector('input[name="cat"]:checked');
        if (!catInput) return alert("Seleccioná categoría");
        
        const catKey = catInput.value;
        const listaPalabras = TODAS_LAS_PALABRAS[catKey];

        estado.total = parseInt(document.getElementById('input-jugadores').value);
        estado.imp = Math.floor(Math.random() * estado.total) + 1;
        estado.palabra = listaPalabras[Math.floor(Math.random() * listaPalabras.length)];
        estado.actual = 1;
        
        showView('game');
        render();
      };

      async function render() {
        document.getElementById('jugador-badge').textContent = `Jugador ${estado.actual}`;
        pistaTxt.textContent = "";
        const display = document.getElementById('palabra-display');
        
        if (estado.actual === estado.imp) {
          display.textContent = "IMPOSTOR";
          pistaTxt.textContent = "¡Miente para sobrevivir!";
        } else {
          display.textContent = estado.palabra.toUpperCase();
          try {
            const r = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${estado.palabra}`);
            const d = await r.json();
            pistaTxt.textContent = d[0]?.meanings[0]?.definitions[0]?.definition || "Sin pista.";
          } catch { pistaTxt.textContent = "Error de pista."; }
        }
      }

      document.getElementById('btn-siguiente').onclick = () => {
        if (estado.actual < estado.total) {
          estado.actual++;
          render();
        } else { showView('final'); }
      };

      // --- GESTIÓN DE CATEGORÍAS PERSONALIZADAS ---
      document.getElementById('btn-guardar').onclick = async () => {
        const nombre = document.getElementById('cat-name').value.trim();
        const palabrasTxt = document.getElementById('cat-words').value.trim();
        if(!nombre || !palabrasTxt) return alert("Faltan datos");

        const res = await fetch('/Endpoints/categorias', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre_categoria: nombre,
            words: palabrasTxt.split(',').map(p => p.trim()).filter(p => p !== ""),
            usuarioNombre: sessionStorage.getItem('user')
          })
        });

        if (res.ok) {
          location.reload();
        } else {
          const err = await res.json();
          alert("Error: " + err.error);
        }
      }

      async function obtenerCategorias() {
        const user = sessionStorage.getItem('user');
        if (!user) return;

        try {
          const res = await fetch(`/Endpoints/CargarCategorias?usuario=${user}`);
          if (res.ok) {
            const categoriasDB = await res.json();
            // Guardar en nuestro objeto global
            categoriasDB.forEach(c => {
              TODAS_LAS_PALABRAS[c.nombre_categoria] = c.words;
            });
            renderizarCategoriasUI(categoriasDB);
          }
        } catch (error) {
          console.error("Error al cargar:", error);
        }
      }

      function renderizarCategoriasUI(lista) {
        const btnNueva = document.getElementById('btn-nueva-cat');
        const contenedor = document.getElementById('contenedor-categorias');
        
        lista.forEach(cat => {
          // Crear el elemento HTML para la nueva categoría
          const label = document.createElement('label');
          label.className = "cursor-pointer";
          label.innerHTML = `
            <input type="radio" name="cat" value="${cat.nombre_categoria}" class="hidden cat-input" />
            <div class="cat-design neo-card p-6 text-center bg-[var(--card)] border-blue-400 border-2">
              <span class="text-4xl block mb-2">${emojis.custom}</span>
              <span class="font-black uppercase text-xs tracking-widest">${cat.nombre_categoria}</span>
            </div>
          `;
          // Insertar antes del botón "Nueva"
          contenedor.insertBefore(label, btnNueva);
        });
      }

      // --- OTROS EVENTOS ---
      document.getElementById('go-register').onclick = () => showView('register');
      document.getElementById('go-login').onclick = () => showView('login');
      document.getElementById('btn-logout').onclick = () => { sessionStorage.clear(); location.reload(); };
      document.getElementById('btn-nueva-cat').onclick = () => document.getElementById('modal-cat').classList.remove('hidden');
      document.getElementById('btn-cancelar').onclick = () => document.getElementById('modal-cat').classList.add('hidden');
      document.getElementById('btn-reiniciar').onclick = () => showView('setup');
      
      document.getElementById('theme-toggle').onclick = () => {
        const isDark = document.documentElement.classList.toggle('dark');
        document.getElementById('theme-toggle').textContent = isDark ? '☀️' : '🌙';
      };

      // Inicializar
      checkAuth();
    </script>
  </body>
</html>