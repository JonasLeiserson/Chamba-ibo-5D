---
import '../styles/global.css';
import CategoriaCard from '../componentes/CategoriaCard.astro';
import palabras from '../data/palabras.json';

const emojis = {
  animales: "🐾",
  comida: "🍕",
  paises: "🌎",
  tecnologia: "💻"
};

const categorias = Object.keys(palabras);
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Impostor Word Generator</title>
    <style is:global>
      /* --- DISEÑO ANTI-IA (NEUBRUTALISM) --- */
      :root {
        --bg: #ffdf6b; /* Amarillo vibrante */
        --card: #ffffff;
        --text: #000000;
        --accent: #2563eb;
        --shadow: #000000;
      }

      .dark {
        --bg: #0f172a;
        --card: #1e293b;
        --text: #ffffff;
        --accent: #38bdf8;
        --shadow: #000000;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
        transition: background-color 0.2s ease;
      }

      /* Botones con estilo "Sticker" */
      .neo-btn {
        background: var(--accent);
        color: white;
        border: 3px solid #000;
        box-shadow: 4px 4px 0px #000;
        transition: all 0.1s;
        font-weight: 900;
        text-transform: uppercase;
      }

      .neo-btn:active {
        box-shadow: 0px 0px 0px #000;
        transform: translate(4px, 4px);
      }

      .neo-card {
        background: var(--card);
        border: 3px solid #000;
        box-shadow: 8px 8px 0px var(--shadow);
      }

      /* Blur mejorado */
      .revelar-box #palabra-display {
        filter: blur(30px);
        opacity: 0;
        transition: all 0.2s scale;
      }

      .revelar-box:active #palabra-display {
        filter: blur(0px);
        opacity: 1;
        transform: scale(1.1);
      }

      .hidden { display: none !important; }

      /* Animación de entrada */
      @keyframes bounceIn {
        0% { transform: scale(0.3); opacity: 0; }
        50% { transform: scale(1.05); }
        70% { transform: scale(0.9); }
        100% { transform: scale(1); opacity: 1; }
      }
      .animate-game { animation: bounceIn 0.5s cubic-bezier(0.17, 0.67, 0.83, 0.67); }
    </style>
  </head>
  <body class="p-4">
    
    <button id="theme-toggle" class="fixed top-4 right-4 z-50 p-3 neo-card rounded-xl text-xl hover:rotate-12 transition-transform">
      🌙
    </button>

    <header class="max-w-2xl mx-auto text-center py-10">
      <h1 class="text-6xl font-black italic tracking-tighter uppercase mb-2" style="-webkit-text-stroke: 2px black;">
        Impostor <span class="text-blue-600">Word</span>
      </h1>
      <p class="font-bold underline decoration-blue-500 decoration-4 text-lg">chamba ibo</p>
    </header>

    <main class="max-w-2xl mx-auto">
      
      <section id="setup-ui" class="neo-card p-8 rounded-none mb-10">
        <h2 class="text-xl font-black mb-6 uppercase italic">1. Elegí Categoría</h2>
        
        <div class="grid grid-cols-2 gap-4 mb-10">
          {categorias.map((cat) => (
            <label class="cursor-pointer group">
              <input type="radio" name="cat" value={cat} class="hidden peer" />
              <div class="neo-card p-4 text-center peer-checked:bg-blue-500 peer-checked:text-white transition-colors group-hover:-translate-y-1">
                <span class="text-3xl block mb-2">{emojis[cat]}</span>
                <span class="font-black uppercase text-sm">{cat}</span>
              </div>
            </label>
          ))}
        </div>

        <h2 class="text-xl font-black mb-4 uppercase italic">2. Cuánta gente?</h2>
        <input type="number" id="input-jugadores" min="3" value="3" 
          class="w-full p-4 neo-card rounded-none mb-8 text-4xl font-black text-center focus:outline-none" />

        <button id="btn-iniciar" class="w-full p-6 neo-btn text-2xl">
          ¡A repartir!
        </button>
      </section>

      <section id="game-ui" class="hidden animate-game neo-card p-10 rounded-none bg-black text-white text-center">
        <div id="jugador-badge" class="inline-block bg-yellow-400 text-black px-4 py-1 font-black uppercase mb-6 rotate-2">
          Jugador 1
        </div>
        
        <div class="revelar-box bg-zinc-800 p-20 border-4 border-white mb-8 cursor-pointer active:bg-zinc-700 transition-all">
          <p class="text-xs font-bold mb-4 text-zinc-400 uppercase tracking-widest">Mantené apretado</p>
          <span id="palabra-display" class="text-5xl font-black tracking-tighter block">---</span>
        </div>

        <p id="pista-api" class="text-yellow-400 font-bold italic text-sm mb-6 min-h-[40px]"></p>

        <button id="btn-siguiente" class="w-full p-5 neo-btn bg-white text-black hover:bg-zinc-200">
          SIGUIENTE →
        </button>
      </section>

      <section id="final-ui" class="hidden animate-game neo-card p-12 bg-blue-600 text-white text-center rounded-none">
        <h2 class="text-6xl font-black mb-6 uppercase italic">¡LISTO!</h2>
        <p class="text-xl font-bold mb-10">Nadie diga nada. <br/> Empiecen a sospechar.</p>
        <button onclick="location.reload()" class="w-full p-6 neo-btn bg-yellow-400 text-black">
          REINICIAR
        </button>
      </section>

    </main>

    <script define:vars={{ palabras }}>
      // DARK MODE FIX
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      toggle.addEventListener('click', () => {
        html.classList.toggle('dark');
        const isDark = html.classList.contains('dark');
        toggle.textContent = isDark ? '☀️' : '🌙';
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });

      // Cargar preferencia guardada
      if (localStorage.getItem('theme') === 'dark') {
        html.classList.add('dark');
        toggle.textContent = '☀️';
      }

      // LÓGICA JUEGO
      const setup = document.getElementById('setup-ui');
      const game = document.getElementById('game-ui');
      const final = document.getElementById('final-ui');
      const btnIniciar = document.getElementById('btn-iniciar');
      const btnSiguiente = document.getElementById('btn-siguiente');
      const display = document.getElementById('palabra-display');
      const pistaTxt = document.getElementById('pista-api');
      const badge = document.getElementById('jugador-badge');

      let estado = { total: 0, actual: 1, imp: 0, palabra: "" };

      async function getPista(p) {
        pistaTxt.textContent = "Buscando pista...";
        try {
          const r = await fetch(`https://api.dictionaryapi.dev/api/v2/entries/en/${p}`);
          const d = await r.json();
          pistaTxt.textContent = d[0]?.meanings[0]?.definitions[0]?.definition || "Sin pista.";
        } catch { pistaTxt.textContent = ""; }
      }

      btnIniciar.addEventListener('click', () => {
        const cat = document.querySelector('input[name="cat"]:checked');
        if (!cat) return alert("ELEGÍ CATEGORÍA!");
        
        estado.total = parseInt(document.getElementById('input-jugadores').value);
        estado.imp = Math.floor(Math.random() * estado.total) + 1;
        const lista = palabras[cat.value];
        estado.palabra = lista[Math.floor(Math.random() * lista.length)];

        setup.classList.add('hidden');
        game.classList.remove('hidden');
        render();
      });

      function render() {
        badge.textContent = `Jugador ${estado.actual}`;
        pistaTxt.textContent = "";
        
        if (estado.actual === estado.imp) {
          display.textContent = "IMPOSTOR";
          pistaTxt.textContent = "¡Mentí o morí!";
        } else {
          display.textContent = estado.palabra.toUpperCase();
          getPista(estado.palabra);
        }
      }

      btnSiguiente.addEventListener('click', () => {
        if (estado.actual < estado.total) {
          estado.actual++;
          render();
        } else {
          game.classList.add('hidden');
          final.classList.remove('hidden');
        }
      });
    </script>
  </body>
</html>