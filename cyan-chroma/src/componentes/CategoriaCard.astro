---
const { emoji, nombre, valor } = Astro.props;
---
<label class="cursor-pointer group">
  <input type="radio" name="cat" value={valor} class="hidden peer" />
  <div class="flex flex-col items-center p-4 rounded-2xl border-2 border-slate-100 bg-white peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all shadow-sm hover:shadow-md">
    <span class="text-3xl mb-2">{emoji}</span>
    <span class="font-bold text-slate-700">{nombre}</span>
  </div>
</label>